{
	"name": "chrome-extension-test",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build": "esbuild src/app/content.ts src/app/background.ts src/app/popup.tsx src/app/mainpage.tsx --bundle --outdir=dist/app --format=esm && tailwindcss -i src/styles.css -o dist/styles.css",
		"build:css": "tailwindcss -i src/styles.css -o dist/styles.css",
		"watch:css": "tailwindcss -i src/styles.css -o dist/styles.css --watch"
	},
	"type": "module",
	"devDependencies": {
		"@tailwindcss/cli": "^4.2.4",
		"@types/chrome": "^0.0.260",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"esbuild": "^0.27.4",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@noble/hashes": "^2.0.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-icons": "^5.6.0"
	}
}
