{
	"manifest_version": 3,
	"name": "DDU Password Manager",
	"version": "1.0.0",
	"description": "The password manager for our DDU exam",
	"permissions": ["tabs", "storage", "scripting"],
	"action": {
		"default_popup": "public/popup.html",
		"default_title": "Hello World"
	},
	"background": {
		"service_worker": "dist/app/background.js",
		"type": "module"
	},
	"web_accessible_resources": [
		{
			"resources": ["public/mainpage.html"],
			"matches": ["<all_urls>"]
		}
	],
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["dist/app/content.js"]
		}
	]
}
